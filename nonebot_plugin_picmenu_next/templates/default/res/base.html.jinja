<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      {{ read_res("css/base.css") | safe }}
      {% if cfg.dark -%}{{ read_res("css/dark.css") | safe }}{% endif %}
      {{ read_res("third-party/katex.min.css") | safe }}
    </style>
    {% if cfg.enable_builtin_code_css -%}
    <style>
      {% if cfg.dark -%}{{ read_res("third-party/code-github-dark.css") | safe }}
      {% else -%}{{ read_res("third-party/code-colorful.css") | safe }}{% endif %}
    </style>
    {% endif -%}
    {% block head %}{% endblock -%}
    {% for f in cfg.additional_css -%}
    <style>
      {{ read_local_file(f) | safe }}
    </style>
    {% endfor -%}
  </head>
  <body>
    <main>
      <div class="main-wrapper">
        {% block main %}{% endblock -%}
        <div class="main-footer">
          Generated by PicMenu-Next v{{ version }} | Made with ❤️ by LgCuwukii☆
        </div>
      </div>
    </main>
  </body>
</html>
